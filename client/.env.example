# Environment Configuration
# Copy this file to .env and update the values as needed

# Application Environment
VITE_NODE_ENV='development'

# API Configuration
VITE_API_URL=http://localhost:4052/api

# WebSocket Configuration
VITE_WS_URL=ws://localhost:4052/ws

# LMS Integration
# Base URL for LMS API - :serialnumber will be replaced with actual controller number
VITE_LMS_BASE_URL=https://lms.macsoftautomations.in/api/serial-numbers/ticket/:serialnumber