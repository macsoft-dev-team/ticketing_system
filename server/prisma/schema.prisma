// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  DONE
  BLOCKED
}

enum ServiceStage {
  TICKET_RAISED // Initial ticket raised
  SERVICE_CENTER_ASSIGNED // Service center assigned by MACSOFT_SUPPORT
  REQUEST_CLEARED_AT_FIELD // Fault cleared on-site by field engineer
  SENT_TO_SERVICE_CENTER // Controller submission request raised submit to service centre
  SUBMITTED_TO_SERVICE_CENTER // Controller submitted to service centre (photo required)
  RECEIVED_AT_SERVICE_CENTER // Controller physically received at centre (photo required)
  DIAGNOSIS_IN_PROGRESS // Diagnosis started to decide repair or replacement
  SPARE_REQUESTED // Spare parts requested (photo required)
  SPARE_APPROVED // Spare request approved by head
  PARTIALY_SPARE_APPROVED // Partial spare request approved by head
  REPAIR_IN_PROGRESS // Controller repair initiated
  REPLACEMENT_IN_PROGRESS // Replacement initiated (alternate to repair)
  REPAIRED // Controller repaired
  READY_FOR_DISPATCH // Controller ready for dispatch (photo required)
  DELIVERED_TO_FIELD // Controller delivered/dispatched back to field
  FIELD_CLEARANCE_APPROVED // Field clearance approved by Head
  TICKET_CLOSED // Ticket formally closed
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Role {
  MACSOFT_ADMIN // Global superuser – all access
  MACSOFT_HEAD // Approver – oversees multiple states/centers
  MACSOFT_SUPPORT // Technical/remote support, assign centers, raise spares
  CUSTOMER_SERVICE_HEAD // Head of a service center (Macsoft or 3rd-party)
  SERVICE_CENTER_TECHNICIAN // Technician repairing/diagnosing at center
  CUSTOMER_FIELD_ENGINEER // Field-level engineer or service person visiting farmer
}

enum Category {
  MCB
  VFD
  RMS
  SPD
  WIRE
  CONNECTOR
  ENCLOSURE_AND_ACCESSORIES
}

enum TransactionType {
  RECEIPT
  DELIVERY
  TICKET_ISSUE
  RETURN
  TRANSFER
  ADJUSTMENT
  REPLACEMENT
}

enum TransactionStatus {
  PENDING_APPROVAL // Transfer requested by SSC, waiting for MACSOFT approval
  APPROVED // Approved by MACSOFT, inventory deducted
  REJECTED // Rejected by MACSOFT
  PENDING // Transfer dispatched, waiting to be received
  RECEIVED
  COMPLETED
  CANCELLED
}

enum InventoryCondition {
  GOOD
  DEFECTIVE
  REPAIRABLE
  SCRAP
}

model State {
  id           Int        @id @default(autoincrement())
  name         String
  stateCode    String?    @unique
  primaryUsers User[]     @relation("PrimaryState")
  users        User[]     @relation("UserStates")
  projects     Project[]  @relation("StateProjects")
  tickets      Ticket[]   @relation("ticketState")
  districts    district[]
}

model district {
  id           Int    @id @default(autoincrement())
  districtName String
  districtCode Int    @unique
  stateCode    Int

  // Relations
  state   State    @relation(fields: [stateCode], references: [id])
  tickets Ticket[]
}

model Organisation {
  id             Int             @id @default(autoincrement())
  name           String
  orgCode        String          @unique
  email          String          @unique
  phone          String          @unique
  address        String?
  isActive       Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime?       @updatedAt
  deletedAt      DateTime?       @map("deleted_at")
  project        Project[]
  users          User[]
  serviceCenters ServiceCenter[]
  templates      template[]
}

model Project {
  id             Int           @id @default(autoincrement())
  name           String
  projectCode    String        @unique
  email          String?       @unique
  address        String?
  stateId        Int?
  isActive       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime?     @updatedAt
  deletedAt      DateTime?     @map("deleted_at")
  state          State?        @relation("StateProjects", fields: [stateId], references: [id])
  organisation   Organisation? @relation(fields: [organisationId], references: [id])
  organisationId Int?
  users          User[]
}

model ServiceCenter {
  id                Int                  @id @default(autoincrement())
  name              String
  orgCode           String?
  centerCode        String               @unique
  email             String               @unique
  address           String?
  isActive          Boolean              @default(false)
  isMacsoft         Boolean              @default(false) // True for MACSOFT head service center
  isMacsoftHead     Boolean              @default(false) // True for MACSOFT head office service center
  serviceableStates String? // Comma-separated list of states this center serves
  users             User[]
  organisation      Organisation?        @relation(fields: [orgCode], references: [orgCode])
  assignedTickets   Ticket[]             @relation("TicketforServiceCenter") // Tickets assigned to this service center
  inventories       Inventory[] // 👈 relation via centerCode
  transactions      ProductTransaction[]
  transfersFrom     ProductTransaction[] @relation("TransferFrom")
  transfersTo       ProductTransaction[] @relation("TransferTo")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime?            @updatedAt
  deletedAt         DateTime?            @map("deleted_at")
}

model User {
  id                     Int                     @id @default(autoincrement())
  name                   String
  phone                  String                  @unique
  password               String
  role                   Role?
  centerCode             String?
  lastLogin              DateTime?               @default(now())
  createdAt              DateTime                @default(now())
  updatedAt              DateTime?               @updatedAt
  deletedAt              DateTime?               @map("deleted_at")
  isActive               Boolean                 @default(true)
  // Relations
  serviceCenter          ServiceCenter?          @relation(fields: [centerCode], references: [centerCode])
  createdTickets         Ticket[]                @relation("CreatedTickets")
  updatedTickets         Ticket[]                @relation("UpdatedTickets")
  messages               Message[]               @relation("UserMessages")
  messageSeens           MessageSeen[]
  sentNotifications      Notification[]          @relation("NotificationCreators")
  notificationRecipients NotificationRecipient[]
  spareRequestsCreated   spareRequest[]          @relation("SpareRequestCreated")
  spareRequestsUpdated   spareRequest[]          @relation("SpareRequestUpdated")
  productTransactions    ProductTransaction[]    @relation("ProductTransactionCreated")
  approvedTransactions   ProductTransaction[]    @relation("ProductTransactionApproved")
  TicketMilestone        TicketMilestone[]
  State                  State?                  @relation("PrimaryState", fields: [stateId], references: [id])
  stateId                Int?
  states                 State[]                 @relation("UserStates")
  projectCode            String?
  project                Project?                @relation(fields: [projectCode], references: [projectCode])
  orgCode                String?
  organisation           Organisation?           @relation(fields: [orgCode], references: [orgCode])
  createdBatches         batch[]                 @relation("BatchCreator")
  updatedBatches         batch[]                 @relation("BatchUpdater")
}

model Ticket {
  id                    Int          @id @default(autoincrement())
  ticketCode            String       @unique
  description           String
  customerName          String
  controllerNo          String
  farmerName            String?
  imei                  String?
  hp                    String?
  motorHpId             Int?
  head                  String?
  motorType             String?
  stateCode             String?
  districtCode          Int?
  district              String?
  village               String?
  block                 String?
  complaintType         String
  faultCode             String
  faultType             String
  status                TicketStatus @default(OPEN)
  priority              String?
  pumpPlacementDepth    String?
  cableLength           String?
  isBuzzerOn            Boolean?     @default(false)
  assignedServiceCenter String? // Service center code assigned based on state
  createdBy             Int
  updatedBy             Int?
  // addon
  code                  String?
  projectName           String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  deletedAt             DateTime?    @map("deleted_at")

  // Relations
  createdByUser       User                 @relation("CreatedTickets", fields: [createdBy], references: [id])
  updatedByUser       User?                @relation("UpdatedTickets", fields: [updatedBy], references: [id])
  serviceCenter       ServiceCenter?       @relation("TicketforServiceCenter", fields: [assignedServiceCenter], references: [centerCode])
  state               State?               @relation("ticketState", fields: [stateCode], references: [stateCode])
  selectedDistrict    district?            @relation(fields: [districtCode], references: [districtCode])
  motorhp             motorhp?             @relation(fields: [motorHpId], references: [id])
  messages            Message[]
  notifications       Notification[]
  productTransactions ProductTransaction[]
  attachments         Attachments[]
  ticketMilestones    TicketMilestone[]
  batchItems          batchItem[]
  backupcreatedAt     DateTime?
  backupurl           String?
  isArchived          Boolean              @default(false)
}

model TicketMilestone {
  id            Int             @id @default(autoincrement())
  ticketId      Int
  stage         ServiceStage
  order         Int
  description   String?
  allowedRoles  String?
  status        MilestoneStatus @default(PENDING)
  startedAt     DateTime?
  completedAt   DateTime?
  eta           DateTime?
  slaDueAt      DateTime?
  photoRequired Boolean         @default(false)
  changedBy     Int?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id])

  // REMOVE the relation name so no back-ref is required
  changer User? @relation(fields: [changedBy], references: [id])

  // keep, but make sure Attachments has milestoneId + relation (see below)
  attachments Attachments[]

  @@unique([ticketId, stage])
  @@index([ticketId, order])
  @@index([status])
}

model Attachments {
  id        Int      @id @default(autoincrement())
  fileName  String
  fileType  String
  fileSize  Int
  fileUrl   String
  createdAt DateTime @default(now())
  messageId Int?
  ticketId  Int?

  // ADD these two lines:
  milestoneId Int?
  milestone   TicketMilestone? @relation(fields: [milestoneId], references: [id])

  message Message? @relation(fields: [messageId], references: [id])
  ticket  Ticket?  @relation(fields: [ticketId], references: [id])
}

model spareRequest {
  id         Int      @id @default(autoincrement())
  ticketCode String
  status     String   @default("PENDING")
  createdBy  Int
  updatedBy  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  createdByUser User               @relation("SpareRequestCreated", fields: [createdBy], references: [id])
  updatedByUser User?              @relation("SpareRequestUpdated", fields: [updatedBy], references: [id])
  spareItems    spareRequestItem[]
}

model spareRequestItem {
  id             Int      @id @default(autoincrement())
  spareRequestId Int
  productId      Int
  quantity       Int
  status         String   @default("REQUESTED")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  spareRequest spareRequest @relation(fields: [spareRequestId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
}

model Product {
  id            Int       @id @default(autoincrement())
  name          String
  productCode   String    @unique
  description   String?
  brandName     String?
  category      Category?
  unitOfMeasure Int? // optional, if you want pcs / sets etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  inventories            Inventory[]
  transactions           ProductTransaction[]
  spareRequestItems      spareRequestItem[]
  ProductTransactionItem ProductTransactionItem[]
}

model ProductTransaction {
  id              Int               @id @default(autoincrement())
  transactionType TransactionType
  status          TransactionStatus @default(PENDING)

  // Center information
  centerCode     String // Current center (for backwards compatibility)
  fromCenterCode String? // Source center (for TRANSFER)
  toCenterCode   String? // Destination center (for TRANSFER)

  // Approval workflow (for SSC transfer requests)
  approvedBy      Int? // MACSOFT admin who approved
  approvedAt      DateTime? // When approved/rejected
  rejectionReason String?   @db.Text // If rejected, reason from approver

  invoiceNo    String?
  billNo       String?
  receiptDate  DateTime?
  deliveryDate DateTime?
  receivedAt   DateTime? // When TRANSFER was received

  ticketId  Int?
  remarks   String?  @db.Text
  createdBy Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  serviceCenter ServiceCenter            @relation(fields: [centerCode], references: [centerCode])
  fromCenter    ServiceCenter?           @relation("TransferFrom", fields: [fromCenterCode], references: [centerCode])
  toCenter      ServiceCenter?           @relation("TransferTo", fields: [toCenterCode], references: [centerCode])
  ticket        Ticket?                  @relation(fields: [ticketId], references: [id])
  items         ProductTransactionItem[]
  createdByUser User                     @relation("ProductTransactionCreated", fields: [createdBy], references: [id])
  approverUser  User?                    @relation("ProductTransactionApproved", fields: [approvedBy], references: [id])
  Product       Product?                 @relation(fields: [productId], references: [id])
  productId     Int?

  @@index([centerCode])
  @@index([fromCenterCode])
  @@index([toCenterCode])
  @@index([status])
  @@index([transactionType])
}

model ProductTransactionItem {
  id            Int                @id @default(autoincrement())
  transactionId Int
  productId     Int? // Optional for unknown products in RETURN
  productName   String? // For unknown products
  condition     InventoryCondition
  quantity      Int // always positive

  // Relations
  transaction ProductTransaction @relation(fields: [transactionId], references: [id])
  product     Product?           @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([transactionId])
}

model Inventory {
  id         Int    @id @default(autoincrement())
  centerCode String
  productId  Int

  goodQty       Int @default(0)
  repairableQty Int @default(0)
  damagedQty    Int @default(0)
  scrapQty      Int @default(0)

  minStock  Int      @default(0)
  maxStock  Int?
  location  String?
  updatedAt DateTime @updatedAt

  // Relations
  serviceCenter ServiceCenter @relation(fields: [centerCode], references: [centerCode])
  product       Product       @relation(fields: [productId], references: [id])

  @@unique([centerCode, productId])
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  senderId  Int
  ticketId  Int

  // Relations
  sender       User           @relation("UserMessages", fields: [senderId], references: [id])
  ticket       Ticket         @relation(fields: [ticketId], references: [id])
  notification Notification[] @relation("messageNotification")
  attachments  Attachments[]
  seenBy       MessageSeen[]
}

model MessageSeen {
  id        Int      @id @default(autoincrement())
  seenAt    DateTime @default(now())
  messageId Int
  userId    Int

  // Relations
  message Message @relation(fields: [messageId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
}

model Notification {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.LongText
  type        String
  createdAt   DateTime @default(now())
  createdById Int
  ticketId    Int?
  messageId   Int?

  // Relations
  message    Message?                @relation("messageNotification", fields: [messageId], references: [id])
  createdBy  User                    @relation("NotificationCreators", fields: [createdById], references: [id])
  ticket     Ticket?                 @relation(fields: [ticketId], references: [id])
  recipients NotificationRecipient[]
}

model NotificationRecipient {
  id             Int       @id @default(autoincrement())
  notificationId Int
  userId         Int
  seen           Boolean   @default(false)
  seenAt         DateTime?

  // Relations
  notification Notification @relation(fields: [notificationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([notificationId, userId])
}

model TicketSequence {
  id         Int      @id @default(autoincrement())
  year       Int      @unique
  lastNumber Int      @default(0)
  prefix     String   @default("TKT")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model batch {
  id          Int         @id @default(autoincrement())
  batchCode   String      @unique
  batchType   batchType?
  batchStatus batchStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  createdBy   Int
  updatedBy   Int?

  // Relations
  batchItems batchItem[]
  creator    User        @relation("BatchCreator", fields: [createdBy], references: [id])
  updater    User?       @relation("BatchUpdater", fields: [updatedBy], references: [id])
}

model batchItem {
  id        Int      @id @default(autoincrement())
  batchId   Int
  ticketId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  batch  batch  @relation(fields: [batchId], references: [id])
  ticket Ticket @relation(fields: [ticketId], references: [id])
}

model settings {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model motorhp {
  id        Int      @id @default(autoincrement())
  label     String   @unique // e.g. "7.5 HP"
  value     Float // numeric value e.g. 7.5
  sortOrder Int? // optional for ordering in dropdowns
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tickets Ticket[]
}

enum batchType {
  RECEIVE_CONTROLLER
  DELIVERY_CONTROLLER
}

enum batchStatus {
  PENDING
  COMPLETED
  CANCELLED
}

// Working hours configuration
model WorkingHours {
  id        Int      @id @default(autoincrement())
  dayOfWeek Int // 1 = Monday, 2 = Tuesday, ..., 7 = Sunday
  startHour Int // 24-hour format (e.g., 9 for 9 AM)
  endHour   Int // 24-hour format (e.g., 18 for 6 PM)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dayOfWeek])
}

// Break times configuration
model BreakTime {
  id          Int      @id @default(autoincrement())
  name        String   @unique // e.g., "Morning Break", "Lunch Break", "Evening Break"
  startHour   Int // 24-hour format
  startMinute Int // minutes
  endHour     Int // 24-hour format
  endMinute   Int // minutes
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Office holidays configuration
model OfficeHoliday {
  id          Int      @id @default(autoincrement())
  name        String // e.g., "New Year", "Christmas"
  date        DateTime // specific date
  description String? // optional description
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date])
}

// Buzzer alert configuration
model BuzzerAlertConfig {
  id          Int      @id @default(autoincrement())
  minHours    Int      @default(3) // Minimum hours before triggering alert
  minMinutes  Int      @default(0) // Additional minutes
  minSeconds  Int      @default(0) // Additional seconds
  maxHours    Int      @default(5) // Maximum hours before stopping alert
  maxMinutes  Int      @default(0) // Additional minutes
  maxSeconds  Int      @default(0) // Additional seconds
  isActive    Boolean  @default(true)
  description String?  @default("Time window for buzzer alerts when customer messages are pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model template {
  id         String        @id @default(cuid())
  name       String
  driveCode  String?
  orgCode    String?
  parameters String?       @db.LongText
  users      String?       @db.LongText
  createdAt  DateTime      @default(now())
  updatedAt  DateTime?     @updatedAt
  customer   Organisation? @relation(fields: [orgCode], references: [orgCode])
}
