server {
    listen 80;
    server_name cri.macsoftautomations.in;
    listen 443 ssl http2;
    listen [::]:443 ssl http2;

    client_max_body_size 100M;

    ssl_certificate /etc/letsencrypt/live/cri.macsoftautomations.in/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/cri.macsoftautomations.in/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

    # For the Admin app
    location /admin/ {
        # Serve the app from /admin/dist folder
        alias /var/www/crisolar/admin/dist/;
        try_files $uri /admin/index.html;
    }

    # For the Warehouse app
    location /warehouse/ {
        # Serve the app from /warehouse/dist folder
        alias /var/www/crisolar/warehouse/dist/;
        try_files $uri /warehouse/index.html;
    }

    location /uploads/ {
      alias /var/www/crisolar/uploads/;
    }

    # For API requests (all apps use the same API)
    location /api {
        proxy_pass http://localhost:3070;  # Replace with your actual API server address if different
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /auth {
        proxy_pass http://localhost:3071;  # Replace with your actual API server address if different
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # For Mobile API requests
